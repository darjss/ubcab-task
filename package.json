{
	"name": "elysia-starter",
	"version": "1.0.0",
	"description": "Shared lunch expense tracking API (Bun, Elysia, Drizzle, Better Auth).",
	"homepage": "https://ubcab-task-production.up.railway.app/openapi",
	"bugs": {
		"url": "https://github.com/darjss/ubcab-task/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/darjss/ubcab-task.git"
	},
	"scripts": {
		"build": "bun build --target=bun ./src/index.ts --outdir ./build",
		"start": "bun run build/index.js",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun run scripts/seed.ts",
		"db:seed:prod": "bun run scripts/seed-prod.ts",
		"dev": "bun run --watch src/index.ts",
		"format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
		"format": "biome check --write .",
		"lint": "biome lint .",
		"test": "bun test tests/api-all.test.ts"
	},
	"dependencies": {
		"@better-auth/redis-storage": "^1.6.9",
		"@elysia/openapi": "^1.4.15",
		"@elysiajs/cors": "^1.4.2",
		"better-auth": "^1.6.9",
		"dotenv": "^17.2.1",
		"drizzle-orm": "0.44.5",
		"drizzle-typebox": "0.3.3",
		"elysia": "1.3.21",
		"ioredis": "^5.10.1",
		"neverthrow": "^8.2.0",
		"pg": "8.16.3",
		"typeid-js": "0.3.0"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@biomejs/biome": "2.2.2",
		"@dbml/cli": "^7.1.1",
		"@types/bun": "1.2.21",
		"@types/pg": "8.15.5",
		"drizzle-kit": "0.31.4"
	},
	"module": "src/index.js",
	"overrides": {
		"@sinclair/typebox": "0.34.33"
	}
}
